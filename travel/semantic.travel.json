{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "ToCoo 国内宿泊予約 Design System — Semantic Tokens (travel)。用途ベース命名・全て primitive.travel.json への参照 (HEX直書きなし)。命名規則§1 準拠。コンポーネント実装はこの層のみ参照 (primitive 直接参照禁止)。",
  "$meta": {
    "layer": "semantic",
    "service": "travel",
    "version": "0.3.0-draft",
    "status": "Draft",
    "basedOn": "GitHub tocoo/coocom-design-system travel/semantic.travel.json 0.2.1-draft (Source of Truth)。設計判断 TVL-0001〜0008 を反映",
    "sourceOfTruth": "https://github.com/tocoo/coocom-design-system/blob/main/travel/semantic.travel.json",
    "created": "2026-07-09",
    "notes": [
      "travel 単独の semantic。他サービスと値を共有せず、相互参照・共通化は行わない (R1/R4)",
      "brand/action/link は宿泊固有値 (link は宿泊 accent 赤 #d10000・保留中=TVL-0005)",
      "会員ランク色は構築しない (破棄済)。Bootstrap 残骸 --primary:#007bff は持ち込まない"
    ]
  },

  "color": {
    "scheme": {
      "$description": "ブランドカラースキーム (TVL-0010)。2スキームを保存: main=第1候補メイン(ロイヤル) / sub=第2候補サブ(インディゴ)。各スキームは主色ハュー由来ロール(tint/soft/base/hover/pressed/ink)・逆色(inverse=補色) を自スキームの値で保持する。全スキーム共通(共有)は器/ニュートラル(surface/gray)・テキスト・境界・状態色・特集橙 (Owner決定 Q2)。DS 既定ビルドは第1候補(main)の値を bound。逆色は Owner指示[m0019] により正規トークン化 (ガイドライン07章の既定=常設化しない、とは差分)",
      "main": {
        "tint":    { "$value": "{color.palette.royal.50}",  "$type": "color", "$description": "メイン Tint (選択面・薄い塗り)", "$status": "bound" },
        "soft":    { "$value": "{color.palette.royal.300}", "$type": "color", "$description": "メイン Soft (補助・図版)", "$status": "bound" },
        "base":    { "$value": "{color.palette.royal.500}", "$type": "color", "$description": "メイン基準色 #2C50C8 (CTA・リンク・選択・フォーカス)", "$status": "bound" },
        "hover":   { "$value": "{color.palette.royal.600}", "$type": "color", "$description": "メイン hover #2340A6", "$status": "bound" },
        "pressed": { "$value": "{color.palette.royal.700}", "$type": "color", "$description": "メイン pressed #1B3488", "$status": "bound" },
        "ink":     { "$value": "{color.palette.royal.900}", "$type": "color", "$description": "メイン Ink #14224A (主色系の濃色テキスト)", "$status": "bound" },
        "inverse": { "$value": "{color.palette.amber.500}", "$type": "color", "$description": "メイン逆色(補色) アンバー #C8912C。主色の対角=補助アクセント/図版/データ可視化用。特集アクセントとは別系統。TVL-0010 (Owner指示[m0019] で正規化)", "$status": "bound" }
      },
      "sub": {
        "tint":    { "$value": "{color.palette.indigo.50}",  "$type": "color", "$description": "サブ Tint", "$status": "bound" },
        "soft":    { "$value": "{color.palette.indigo.300}", "$type": "color", "$description": "サブ Soft", "$status": "bound" },
        "base":    { "$value": "{color.palette.indigo.500}", "$type": "color", "$description": "サブ基準色 #4845D4", "$status": "bound" },
        "hover":   { "$value": "{color.palette.indigo.600}", "$type": "color", "$description": "サブ hover #3936B0", "$status": "bound" },
        "pressed": { "$value": "{color.palette.indigo.700}", "$type": "color", "$description": "サブ pressed #2C2A8C", "$status": "bound" },
        "ink":     { "$value": "{color.palette.indigo.900}", "$type": "color", "$description": "サブ Ink #191840", "$status": "bound" },
        "inverse": { "$value": "{color.palette.gold.500}", "$type": "color", "$description": "サブ逆色(補色) ゴールド #C8B12C。主色の対角=補助アクセント。特集アクセントとは別系統。TVL-0010 (Owner指示[m0019] で正規化)", "$status": "bound" }
      }
    },
    "brand": {
      "primary":        { "$value": "{color.scheme.main.base}",  "$type": "color", "$description": "宿泊主色=メイン (ロイヤル #2C50C8)。メインスキームの base。TVL-0010 (旧 navy #283593)", "$status": "bound" },
      "primaryHover":   { "$value": "{color.scheme.main.hover}", "$type": "color", "$description": "主色 hover (#2340A6)。TVL-0010", "$status": "bound" },
      "secondary":      { "$value": "{color.scheme.sub.base}",   "$type": "color", "$description": "宿泊副色=サブ (インディゴ #4845D4)。サブスキームの base。TVL-0010 で新設", "$status": "bound" },
      "secondaryHover": { "$value": "{color.scheme.sub.hover}",  "$type": "color", "$description": "副色 hover (#3936B0)。TVL-0010", "$status": "bound" }
    },
    "action": {
      "primary": {
        "bg":      { "$value": "{color.brand.primary}",      "$type": "color", "$description": "主CTA背景", "$status": "bound" },
        "text":    { "$value": "{color.palette.white}",      "$type": "color", "$status": "bound" },
        "hoverBg": { "$value": "{color.brand.primaryHover}", "$type": "color", "$description": "主CTA hover 背景", "$status": "bound", "$note": "TVL-0010 でロイヤルの hover 暗色を採用し bound 化 (旧 follow-up #4 placeholder)" }
      },
      "secondary": {
        "bg":   { "$value": "{color.palette.white}",    "$type": "color", "$description": "白CTA (実測: bg白/文字#212121/pill)。variant 名 secondary は GOV-0002 で正式確定", "$status": "bound" },
        "text": { "$value": "{color.palette.gray.900}", "$type": "color", "$status": "bound", "$note": "TVL-0003 (Q2 解消) で bound 化" }
      }
    },
    "text": {
      "strong":  { "$value": "{color.palette.gray.900}", "$type": "color", "$description": "見出し #212121", "$status": "bound", "$note": "TVL-0003" },
      "body":    { "$value": "{color.palette.gray.800}", "$type": "color", "$description": "本文 #424242 (白背景 ≈9.7:1 AA適合)", "$status": "bound", "$note": "TVL-0003" },
      "muted":   { "$value": "{color.palette.gray.600}", "$type": "color", "$status": "bound" },
      "inverse": { "$value": "{color.palette.white}",    "$type": "color", "$status": "bound" },
      "link":    { "$value": "{color.palette.red.500}",  "$type": "color", "$description": "宿泊 link/accent 赤 #d10000 (実サイト由来・事実値)。実測ではリンクに主色の使用も観測=揺れ", "$status": "placeholder", "$note": "TVL-0005 保留 (赤 #d10000 と主色の併存)。検討トリガー: リンク UI 着手時" }
    },
    "surface": {
      "default": { "$value": "{color.palette.white}",    "$type": "color", "$status": "bound" },
      "subtle":  { "$value": "{color.palette.gray.50}",  "$type": "color", "$status": "bound" },
      "muted":   { "$value": "{color.palette.gray.100}", "$type": "color", "$status": "bound" },
      "inverse": { "$value": "{color.palette.gray.900}", "$type": "color", "$status": "bound", "$note": "TVL-0003 (Q2 解消) で bound 化" }
    },
    "border": {
      "subtle":  { "$value": "{color.palette.gray.300}", "$type": "color", "$status": "bound" },
      "default": { "$value": "{color.palette.gray.400}", "$type": "color", "$status": "bound", "$note": "非テキストUI境界としての AA (3:1) は用途により未達の可能性。監査は R9 全面適用の運用で個別確認" },
      "strong":  { "$value": "{color.palette.gray.500}", "$type": "color", "$status": "bound" }
    },
    "state": {
      "success": { "$value": "{color.palette.green.500}", "$type": "color", "$status": "placeholder", "$note": "follow-up #5 宿泊固有の success 色未取得 (IB 値の暫定参照)" },
      "error":   { "$value": "{color.palette.red.500}",   "$type": "color", "$description": "顧客向け error #d10000。リンク赤と同値だが用途トークンで分離 (付随論点)", "$status": "bound" }
    },
    "accent": {
      "campaign": { "$value": "{color.palette.orange.500}", "$type": "color", "$description": "特集/キャンペーン用 accent #EF4123 (ブランド主色と分離)", "$status": "bound" }
    },
    "focus": {
      "ring": { "$value": "{color.brand.primary}", "$type": "color", "$description": "フォーカスリング (outline ベース=命名規則§8)。白背景 ≈10.4:1", "$status": "bound" }
    },
    "icon": {
      "rating": { "$value": null, "$type": "color", "$description": "ReviewStars 星の色 (宿泊固有)", "$status": "placeholder", "$note": "星の色は未抽出。空欄でなく null で構造化。検討トリガー: ReviewStars 実装着手時。アイコン体系は FA6 (TVL-0006)" }
    }
  },

  "font": {
    "body": {
      "family":     { "$value": "{typography.fontFamily.sans}",    "$type": "fontFamily", "$description": "本文・UI ゴシック (LINE Seed JP・Q1)", "$status": "bound" },
      "size":       { "$value": "{typography.size.md}",            "$type": "dimension", "$description": "本文 1rem (16px相当)", "$status": "bound", "$note": "TVL-0001" },
      "lineHeight": { "$value": "{typography.lineHeight.relaxed}", "$type": "number", "$description": "1.8 (実測)", "$status": "bound", "$note": "TVL-0001" }
    },
    "heading": {
      "family": { "$value": "{typography.fontFamily.heading}", "$type": "fontFamily", "$description": "一覧/カード見出しゴシック 700 (Q2)", "$status": "bound" },
      "h2Size": { "$value": "{typography.size.3xl}",           "$type": "dimension", "$description": "h2 2rem (32px相当・実測)", "$status": "bound", "$note": "TVL-0001" }
    },
    "display": {
      "family": { "$value": "{typography.fontFamily.mincho}",   "$type": "fontFamily", "$description": "明朝 Display/Hero/特集/詳細施設名 (Noto Serif JP・Q8)", "$status": "bound", "$note": "タイポグラフィ設計方針 2026-07-10 Q8" },
      "lgSize": { "$value": "{typography.size.display-lg}",     "$type": "dimension", "$description": "ヒーロー明朝 3rem (48px相当・Q4)", "$status": "bound", "$note": "Q4 で追加" }
    },
    "price": {
      "family":      { "$value": "{typography.fontFamily.number}", "$type": "fontFamily", "$description": "価格・数字 (本文と同族・Q3)", "$status": "bound", "$note": "旧: Barlow/Roboto。Q3 で本文ゴシックに統合" },
      "weight":      { "$value": "{typography.fontWeight.bold}",   "$type": "fontWeight", "$description": "価格ウェイト 700 (Q3)。強調はサイズと tabular-nums で担保", "$status": "bound", "$note": "旧: black 900。タイポグラフィ設計方針 2026-07-10 Q3 で 700 に変更" },
      "numberSize":  { "$value": "{typography.size.xl}",           "$type": "dimension", "$description": "価格数字 1.25rem (20px相当・実測)", "$status": "bound", "$note": "TVL-0001" },
      "captionSize": { "$value": "{typography.size.xs}",           "$type": "dimension", "$description": "補助価格 0.75rem (12px相当・実測)", "$status": "bound", "$note": "TVL-0001" }
    }
  },

  "radius": {
    "action": { "$value": "{radius.full}", "$type": "dimension", "$description": "ボタン形状 pill (実測 999px)。宿泊のサービスシグネチャ", "$status": "bound" },
    "card":   { "$value": "{radius.md}",   "$type": "dimension", "$status": "placeholder", "$note": "カード実px (角丸/影/余白) 未取得。暫定 md (TVL-0008)" }
  },

  "motion": {
    "transition": {
      "duration": { "$value": "{motion.duration.base}",   "$type": "duration", "$status": "placeholder", "$note": "follow-up #3 (TVL-0008)" },
      "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier", "$status": "placeholder", "$note": "follow-up #3" }
    }
  },

  "icon": {
    "reviewSize": { "$value": "{iconSize.sm}", "$type": "dimension", "$description": "ReviewStars 星のサイズ。アイコン体系 FA6 (TVL-0006)", "$status": "bound", "$note": "サイズは確定。色は color.icon.rating (placeholder) 参照" }
  },

  "elevation": {
    "sticky":  { "$value": "{elevation.z.sticky}",  "$type": "number", "$status": "bound" },
    "overlay": { "$value": "{elevation.z.overlay}", "$type": "number", "$status": "bound" },
    "modal":   { "$value": "{elevation.z.modal}",   "$type": "number", "$status": "bound" }
  }
}
