{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "ToCoo Design System — Primitive Tokens(国内宿泊予約 travel 専用)。3独立DS(ADR-0022)につき本ファイルは travel のみが参照する。混載初版 primitive.json (0.1.0-draft) を実装着手ガイド§1の割当指針に従い分割(値は不変)。中立色・構造スケールは同値でも共有ではなく travel 独自定義。命名規則§1(属性ベース {category}.{attribute}.{step})準拠。",
  "$meta": {
    "layer": "primitive",
    "service": "travel",
    "serviceLabel": "国内宿泊予約 (tocoo/tocoo_travel)",
    "version": "0.2.0-draft",
    "status": "Draft",
    "basedOn": "共通/primitive.json 0.1.0-draft (旧Phase 3 混載初版) — 実装着手ガイド§1で分割。値は変更していない",
    "created": "2026-07-02",
    "rules": [
      "属性ベース命名({category}.{attribute}.{step})",
      "コンポーネント実装からの直接参照は禁止(Semantic 経由のみ)",
      "$status: bound=確定扱い / placeholder=未確定(Q番号・follow-up番号を $note に併記)",
      "他サービス(rental-car/inbound)のブランド固有色は本ファイルに含めない(ADR-0022)",
      "管理画面系の色(teal #1798A5 等)は顧客向けDSに持ち込まない(P3/ADR-0012)",
      "Bootstrap残骸 --primary:#007bff (C-11/D-5) は本DSに持ち込まない"
    ]
  },

  "color": {
    "palette": {
      "white": { "$value": "#ffffff", "$type": "color", "$description": "C-05 揺れなし", "$status": "bound" },
      "black": { "$value": "#000000", "$type": "color", "$description": "C-05 揺れなし", "$status": "bound" },

      "gray": {
        "50":  { "$value": "#f9f9f9", "$type": "color", "$description": "C-06 最も明るい面(宿泊実装値)", "$status": "bound" },
        "100": { "$value": "#f5f5f5", "$type": "color", "$description": "C-06 surface(宿泊 #f5f5f5。layerB で #f5f5fa も観測=DS内正規化候補🟢)", "$status": "bound" },
        "200": { "$value": "#eeeeee", "$type": "color", "$description": "C-06 surface 段階", "$status": "bound" },
        "300": { "$value": "#e0e0e0", "$type": "color", "$description": "C-07 border subtle(宿泊 #DADCE0 実装値はDS内正規化候補🟢)", "$status": "bound" },
        "400": { "$value": "#cccccc", "$type": "color", "$description": "C-07 border default", "$status": "bound" },
        "500": { "$value": "#bcbcbc", "$type": "color", "$description": "C-07 border strong(宿泊 pearl-gray)", "$status": "bound" },
        "600": { "$value": "#9e9e9e", "$type": "color", "$description": "C-04 text muted(宿泊 #9E9E9E)", "$status": "bound" },
        "700": { "$value": "#616161", "$type": "color", "$description": "C-04 text muted strong(宿泊 #616161。補助価格等)", "$status": "bound" },
        "800": { "$value": "#424242", "$type": "color", "$description": "C-03 本文(宿泊 $COLOR_TEXT・layerB実測一致)", "$status": "placeholder", "$note": "Q2 テキスト主色の正値未確定。暫定運用=2段(#424242本文+#212121見出し)" },
        "900": { "$value": "#212121", "$type": "color", "$description": "C-03 見出し(layerB実測 h2 #212121)", "$status": "placeholder", "$note": "Q2" }
      },

      "navy": {
        "500": { "$value": "#283593", "$type": "color", "$description": "C-01 宿泊 brand primary。揺れなし=確定(layerB §1 本番実測一致)", "$status": "bound" },
        "700": { "$value": null, "$type": "color", "$description": "brand primary hover 用暗色。候補として layerB で $color-primary-dark #191E3B を観測(面色として)だが hover 用途の実測は未取得", "$status": "placeholder", "$note": "hover 暗色は未抽出(primitive 初版 $note 継承)。実測補完待ち。暫定は hover opacity 参照(follow-up #4)" }
      },

      "red": {
        "500": { "$value": "#d10000", "$type": "color", "$description": "C-02/C-09 宿泊 link/accent・顧客向け error。リンク赤とエラー赤の同値整理は付随論点(用途トークンで分離済)", "$status": "bound" }
      },

      "orange": {
        "500": { "$value": "#ef4123", "$type": "color", "$description": "特集アクセント(ultra-tocoo で最頻出18回=layerB §2)。ブランド主色と分離。キャンペーン用途のみ", "$status": "bound" }
      },

      "green": {
        "500": { "$value": "#58b85d", "$type": "color", "$description": "C-08 state success。宿泊固有の success 色は未抽出のためインバウンド実装値を暫定参照", "$status": "placeholder", "$note": "follow-up #5 宿泊の success 状態色未取得。IB #58b85d を暫定参照" }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "sans":    { "$value": "'Noto Sans JP', -apple-system, BlinkMacSystemFont, 'Hiragino Sans', sans-serif", "$type": "fontFamily", "$description": "T-01 和文base(layerB実測: Roboto+Noto Sans JP 完全一致)", "$status": "bound" },
      "heading": { "$value": "'Murecho', 'Noto Sans JP', sans-serif", "$type": "fontFamily", "$description": "T-01 見出し(layerB実測: h2 Murecho 700)。特集頁で h2 が Noto 14px の頁あり=D-3 揺れ・DS内正規化候補🟢", "$status": "bound" },
      "latin":   { "$value": "'Roboto', sans-serif", "$type": "fontFamily", "$description": "T-02 欧文", "$status": "bound" },
      "number":  { "$value": "'Barlow', 'Roboto', sans-serif", "$type": "fontFamily", "$description": "T-03 数字強調(宿泊 $FONT_NUMBER=Barlow。layerB実測は価格数字 Roboto 900)", "$status": "bound" },
      "mincho":  { "$value": "'Ryumin', '游明朝', serif", "$type": "fontFamily", "$description": "宿泊 $FONT_MINCHO。限定用途(travel 固有)", "$status": "bound" }
    },
    "fontWeight": {
      "regular": { "$value": 400, "$type": "fontWeight", "$status": "bound" },
      "medium":  { "$value": 500, "$type": "fontWeight", "$status": "bound" },
      "bold":    { "$value": 700, "$type": "fontWeight", "$status": "bound" },
      "black":   { "$value": 900, "$type": "fontWeight", "$description": "価格数字 Roboto 900(layerB §2 実測)", "$status": "bound" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.3, "$type": "number", "$status": "placeholder", "$note": "Q4 基準確定で再調整" },
      "normal":  { "$value": 1.5, "$type": "number", "$status": "placeholder", "$note": "Q4" },
      "relaxed": { "$value": 1.8, "$type": "number", "$description": "宿泊本文実測 1.8(layerB §1)", "$status": "placeholder", "$note": "Q4。宿泊の現行実測値" }
    },
    "size": {
      "xs":  { "$value": "12px", "$type": "dimension", "$description": "補助価格 12px(layerB §2 実測)", "$status": "placeholder", "$note": "Q4 root 基準未確定。スケール体系は確定、px値は root 確定後にバインド" },
      "sm":  { "$value": "14px", "$type": "dimension", "$status": "placeholder", "$note": "Q4" },
      "md":  { "$value": "16px", "$type": "dimension", "$description": "宿泊本文実測 16px(layerB §1)", "$status": "placeholder", "$note": "Q4" },
      "lg":  { "$value": "18px", "$type": "dimension", "$status": "placeholder", "$note": "Q4" },
      "xl":  { "$value": "20px", "$type": "dimension", "$description": "価格数字 20px(layerB §2 実測)", "$status": "placeholder", "$note": "Q4" },
      "2xl": { "$value": "24px", "$type": "dimension", "$status": "placeholder", "$note": "Q4" },
      "3xl": { "$value": "32px", "$type": "dimension", "$description": "宿泊 h2 32px(layerB §1 実測)", "$status": "placeholder", "$note": "Q4" },
      "4xl": { "$value": "40px", "$type": "dimension", "$status": "placeholder", "$note": "Q4" }
    }
  },

  "spacing": {
    "0":  { "$value": "0px",  "$type": "dimension", "$status": "bound" },
    "1":  { "$value": "4px",  "$type": "dimension", "$description": "base×1", "$status": "placeholder", "$note": "Q3 base unit(4/5/8px)未確定。宿泊現状は 16px map($PADDING)。刻み体系は確定、値はQ3確定後にバインド" },
    "2":  { "$value": "8px",  "$type": "dimension", "$status": "placeholder", "$note": "Q3" },
    "3":  { "$value": "12px", "$type": "dimension", "$status": "placeholder", "$note": "Q3" },
    "4":  { "$value": "16px", "$type": "dimension", "$status": "placeholder", "$note": "Q3" },
    "5":  { "$value": "20px", "$type": "dimension", "$status": "placeholder", "$note": "Q3" },
    "6":  { "$value": "24px", "$type": "dimension", "$status": "placeholder", "$note": "Q3" },
    "8":  { "$value": "32px", "$type": "dimension", "$status": "placeholder", "$note": "Q3" },
    "10": { "$value": "40px", "$type": "dimension", "$status": "placeholder", "$note": "Q3" },
    "12": { "$value": "48px", "$type": "dimension", "$status": "placeholder", "$note": "Q3" },
    "16": { "$value": "64px", "$type": "dimension", "$status": "placeholder", "$note": "Q3" }
  },

  "size": {
    "container": {
      "sm": { "$value": "975px",  "$type": "dimension", "$description": "S-03 宿泊 foundation 実装値", "$status": "bound" },
      "md": { "$value": "1195px", "$type": "dimension", "$status": "bound" },
      "lg": { "$value": "1425px", "$type": "dimension", "$status": "bound" }
    }
  },

  "radius": {
    "sm":   { "$value": "4px",    "$type": "dimension", "$status": "bound" },
    "md":   { "$value": "8px",    "$type": "dimension", "$status": "bound" },
    "lg":   { "$value": "16px",   "$type": "dimension", "$status": "bound" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "R-01/R-02 pill(宿泊 .c-btn・白CTA radius 999px=layerB実測)", "$status": "bound" }
  },

  "shadow": {
    "sm": { "$value": "0 1px 2px rgba(0,0,0,0.05)",  "$type": "shadow", "$description": "R-03 宿泊は box-shadow 定義ありだが実値未抽出", "$status": "placeholder", "$note": "follow-up #13 シャドウ実値未抽出。暫定値で据置き" },
    "md": { "$value": "0 2px 8px rgba(0,0,0,0.10)",  "$type": "shadow", "$status": "placeholder", "$note": "follow-up #13" },
    "lg": { "$value": "0 8px 24px rgba(0,0,0,0.15)", "$type": "shadow", "$status": "placeholder", "$note": "follow-up #13" }
  },

  "border": {
    "width": {
      "thin":  { "$value": "1px", "$type": "dimension", "$status": "bound" },
      "thick": { "$value": "2px", "$type": "dimension", "$status": "bound" }
    },
    "style": {
      "solid": { "$value": "solid", "$type": "strokeStyle", "$status": "bound" }
    }
  },

  "elevation": {
    "z": {
      "base":     { "$value": 0,    "$type": "number", "$status": "bound" },
      "dropdown": { "$value": 1000, "$type": "number", "$status": "bound" },
      "sticky":   { "$value": 1100, "$type": "number", "$status": "bound" },
      "overlay":  { "$value": 1200, "$type": "number", "$status": "bound" },
      "modal":    { "$value": 1300, "$type": "number", "$status": "bound" },
      "toast":    { "$value": 1400, "$type": "number", "$status": "bound" }
    }
  },

  "motion": {
    "duration": {
      "fast": { "$value": "150ms", "$type": "duration", "$status": "placeholder", "$note": "follow-up #3 宿泊の transition 未取得" },
      "base": { "$value": "300ms", "$type": "duration", "$description": "IB `all .3s ease` の暫定参照(宿泊固有値は未取得)", "$status": "placeholder", "$note": "follow-up #3" },
      "slow": { "$value": "500ms", "$type": "duration", "$status": "placeholder", "$note": "follow-up #3" }
    },
    "easing": {
      "standard": { "$value": "ease", "$type": "cubicBezier", "$description": "IB 実装値の暫定参照", "$status": "placeholder", "$note": "follow-up #3" }
    }
  },

  "iconSize": {
    "sm": { "$value": "16px", "$type": "dimension", "$status": "bound", "$note": "Q8 アイコン体系(Material+FA 混在)は別途。ここはサイズスケールのみ" },
    "md": { "$value": "20px", "$type": "dimension", "$status": "bound" },
    "lg": { "$value": "24px", "$type": "dimension", "$status": "bound" },
    "xl": { "$value": "32px", "$type": "dimension", "$status": "bound" }
  },

  "breakpoint": {
    "sm": { "$value": "600px",  "$type": "dimension", "$description": "B-01 宿泊 foundation(Bootstrap準拠4段)自身の実装値", "$status": "bound", "$note": "Q5 統一値のADR批准は未決だが、宿泊自身の実装値のためバインド" },
    "md": { "$value": "768px",  "$type": "dimension", "$status": "bound", "$note": "Q5" },
    "lg": { "$value": "992px",  "$type": "dimension", "$status": "bound", "$note": "Q5" },
    "xl": { "$value": "1200px", "$type": "dimension", "$status": "bound", "$note": "Q5" }
  }
}
